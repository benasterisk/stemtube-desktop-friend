{
  "productName": "StemTube Desktop Friend",
  "version": "1.0.1",
  "identifier": "com.stemtube.desktop.friend",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5011"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "StemTube Desktop Friend",
        "width": 560,
        "height": 340,
        "resizable": false,
        "center": true,
        "decorations": true,
        "url": "splash.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Music analysis and stem extraction (Friend edition)",
    "longDescription": "StemTube Desktop Friend — Beta tester edition with YouTube download, stem extraction, chord detection, and beat tracking via madmom. No license required.",
    "copyright": "Copyright 2026 StemTube",
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "compression": "lzma",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
